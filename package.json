{
  "name": "@obinexusltd/pascal-polycall",
  "version": "1.0.0",
  "description": "Free Pascal source binding for libpolycall 1.5",
  "main": "index.js",
  "type": "commonjs",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json",
    "./src/*": "./src/*",
    "./include/*": "./include/*",
    "./generated/*": "./generated/*",
    "./dist/*": "./dist/*",
    "./examples/*": "./examples/*",
    "./tests/*": "./tests/*",
    "./scripts/*": "./scripts/*",
    "./config": "./pascal-polycallrc",
    "./manifest": "./polycall-binding.json"
  },
  "files": [
    "index.js",
    "src/",
    "include/",
    "generated/",
    "dist/",
    "examples/",
    "tests/",
    "scripts/",
    "Makefile",
    "pascal-polycallrc",
    "polycall-binding.json",
    "README.md",
    "TODO.md",
    "LICENSE"
  ],
  "directories": {
    "lib": "src",
    "src": "src",
    "include": "include",
    "generated": "generated",
    "dist": "dist",
    "example": "examples",
    "test": "tests",
    "scripts": "scripts"
  },
  "scripts": {
    "build": "make",
    "build:pascal": "make pascal",
    "test": "make test && make test-pascal-if-available && npm run verify:dry && npm run test:package",
    "test:pascal": "make test-pascal",
    "test:package": "node tests/package.test.js",
    "verify:dry": "make verify-dry",
    "verify": "npm test",
    "prepack": "npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obinexus/pascal-polycall.git"
  },
  "keywords": [
    "libpolycall",
    "polycall",
    "pascal",
    "freepascal",
    "ffi"
  ],
  "author": "Nnamdi Michael Okpala <okpalan@protonmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/obinexus/pascal-polycall/issues"
  },
  "homepage": "https://github.com/obinexus/pascal-polycall#readme"
}
